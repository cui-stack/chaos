.page {
    padding: 0 38rpx
}

.page_head {
    text-align: center;
    margin-top: 104rpx;
    margin-bottom: 60rpx;
}

.page_head image {
    width: 120rpx;
    height: 120rpx;
}

.page_search {
    display: flex;
    justify-content: space-between;
    align-items: center;

    background: rgba(248, 248, 247, 1);
    border-radius: 40rpx;
    border: 2rpx solid rgba(238, 238, 238, 1);

    width: 674rpx;
}

.page_search_title {
    font-size: 30rpx;
    font-family: PingFangSC-Regular, PingFang SC;
    font-weight: 400;
    color: rgba(166, 166, 166, 1);
    line-height: 42rpx;
    padding: 28rpx 36rpx;
}

.page_search mp-icon {
    margin-right: 24rpx;

}

.page_list {
    margin: 48rpx 0;
    border-radius: 10rpx;
    border: 1rpx solid rgba(231, 232, 235, 1);
}

.page_list_item {
    padding: 24rpx 0;
    margin: 0 48rpx;
    text-align: left;
    font-size: 28rpx;
    font-family: PingFangSC-Regular, PingFang SC;
    font-weight: 400;
    color: rgba(129, 129, 129, 1);
    line-height: 40rpx;
}

.page_list_line {
    border-bottom: 1rpx solid rgba(229, 229, 229, 1);
}