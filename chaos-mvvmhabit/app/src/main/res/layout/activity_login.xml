<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:binding="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="viewModel"
            type="com.cui.tech.mh.vm.LoginViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/splash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <include
            android:id="@+id/toolbar"
            layout="@layout/base_toolbar" />

        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_85"
            android:src="@mipmap/splash_pongo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/toolbar" />

        <EditText
            android:id="@+id/et_username"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_50"
            android:layout_marginStart="@dimen/dp_24"
            android:layout_marginTop="@dimen/dp_40"
            android:layout_marginEnd="@dimen/dp_24"
            android:background="@drawable/bg_input_default"
            android:gravity="start|center_vertical"
            android:hint="@string/input_username_hint"
            android:lines="1"
            android:maxLines="1"
            android:paddingStart="20dp"
            android:paddingEnd="@dimen/dp_140"
            android:singleLine="true"
            android:text="@={viewModel.username}"
            android:textSize="@dimen/sp_14"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_logo"
            binding:onFocusChangeCommand="@{viewModel.onFocusUsername}" />

        <TextView
            android:id="@+id/tv_username_clear"
            android:layout_width="@dimen/dp_24"
            android:layout_height="@dimen/dp_24"
            android:layout_marginEnd="@dimen/dp_15"
            android:background="@mipmap/base_text_clear"
            android:visibility="@{viewModel.isShowTvUsernameClear}"
            app:layout_constraintBottom_toBottomOf="@id/et_username"
            app:layout_constraintEnd_toEndOf="@id/et_username"
            app:layout_constraintTop_toTopOf="@id/et_username"
            binding:onClickCommand="@{viewModel.clearUsername}" />

        <EditText
            android:id="@+id/et_password"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_52"
            android:layout_marginStart="@dimen/dp_24"
            android:layout_marginTop="@dimen/dp_16"
            android:layout_marginEnd="@dimen/dp_24"
            android:background="@drawable/bg_input_default"
            android:gravity="start|center_vertical"
            android:hint="@string/input_password_hint"
            android:inputType="textPassword"
            android:paddingStart="20dp"
            android:paddingEnd="@dimen/dp_140"
            android:text="@={viewModel.password}"
            android:textSize="@dimen/sp_14"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/et_username" />

        <TextView
            android:id="@+id/tv_password_visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp_15"
            android:background="@mipmap/base_password_invisible"
            app:layout_constraintBottom_toBottomOf="@id/et_password"
            app:layout_constraintEnd_toEndOf="@id/et_password"
            app:layout_constraintTop_toTopOf="@id/et_password"
            binding:onClickCommand="@{viewModel.changeShowPassword}" />

        <Button
            android:id="@+id/bt_login"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_50"
            android:layout_marginStart="@dimen/dp_24"
            android:layout_marginTop="@dimen/dp_32"
            android:layout_marginEnd="@dimen/dp_24"
            android:background="@drawable/bg_button_default"
            android:elevation="@dimen/dp_3"
            android:gravity="center"
            android:text="@string/login"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_18"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/et_password"
            binding:onClickCommand="@{viewModel.doLogin}" />

        <TextView
            android:id="@+id/tv_other_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_20"
            android:text="@string/login_by_other_way"
            android:textColor="@color/gray_medium"
            android:textSize="@dimen/sp_14"
            app:layout_constraintBottom_toTopOf="@id/iv_quick_login"
            app:layout_constraintEnd_toStartOf="@id/divider_right"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@id/divider_left" />

        <View
            android:id="@+id/divider_left"
            android:layout_width="@dimen/dp_95"
            android:layout_height="@dimen/dp_1"
            android:layout_marginEnd="@dimen/dp_8"
            android:background="@color/gray_hover"
            app:layout_constraintBottom_toBottomOf="@id/tv_other_login"
            app:layout_constraintEnd_toEndOf="@id/tv_other_login"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_other_login" />

        <View
            android:id="@+id/divider_right"
            android:layout_width="@dimen/dp_95"
            android:layout_height="@dimen/dp_1"
            android:layout_marginStart="@dimen/dp_8"
            android:background="@color/gray_hover"
            app:layout_constraintBottom_toBottomOf="@id/tv_other_login"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tv_other_login"
            app:layout_constraintTop_toTopOf="@id/tv_other_login" />

        <ImageView
            android:id="@+id/iv_quick_login"
            android:layout_width="@dimen/dp_44"
            android:layout_height="@dimen/dp_44"
            android:layout_marginBottom="@dimen/dp_16"
            android:clickable="true"
            android:src="@mipmap/base_wx_login"
            app:layout_constraintBottom_toTopOf="@id/tv_recommend"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_recommend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_20"
            android:text="@string/recommend"
            android:textColor="@color/gray_light"
            android:textSize="@dimen/sp_14"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
