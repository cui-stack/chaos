.page {
    background-color: #fff;
    height: 100%;
    margin: 18px;
}

.page_head {
    display: flex;
    justify-content: flex-start;
    margin: 5px;
}

.page_logo {
    width: 40px;
    height: 40px;
}

.page_logo_r {
    margin: auto 13px;
    font-size: 20px;
}

.page_body {
    margin-top: 120px;
}

.page_body_title {
    color: #000;
    font-size: 28px;
    margin-bottom: 15px;
}

.page_body_button {
    color: #ffffff;
    border-radius: 2px;
    background-color: #07C160;
}

.page_foot {
    bottom: 20px;
    position: fixed;
    width: 100%;
}

.page_footer_wrap {
    display: flex;
    justify-content: center;
    font-size: 14px;
}

.page_footer_title {
    color: #888;
}

.page_footer_xy {
    color: #576B95;
}
