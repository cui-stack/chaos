.page {
    position: fixed;
    bottom: 0px;
    width: 100%;
    height: 400px;
    background-color: #fff;
    color: black;
    z-index: 17;
    text-align: center;
}

.page_bt {
    background-color: #fd6b6c;
    border-top: 1px #eee solid;
    padding: 15px 0px;
    display: flex;
    justify-content: center;
    color: white;
    width: 60%;
    margin: 0 auto;
}

