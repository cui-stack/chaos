.page {
    position: relative;
}


.page_bt {
    width: 100%;
    position: absolute;
    top: 0px;
    height: 100rpx;
    z-index: 100;
    opacity: 0;
}

.page_slot {
    text-align: center;
    display: inline-block;
    font-size: 16px;
    font-weight: bold;
}

.page_text {
    display: inline-block;
    text-align: center;
    font-size: 30rpx;
    font-family: PingFangSC-Regular, PingFang SC;
    font-weight: 700;
    color: rgba(51, 51, 51, 1);
    line-height: 44rpx;
}
